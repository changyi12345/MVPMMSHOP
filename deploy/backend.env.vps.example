NODE_ENV=production

# Supabase pooler (or Neon) — copy from your cloud DB dashboard
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

PORT=4000
JWT_SECRET=change-to-long-random-string-min-32-chars
APP_BASE_URL=https://rankage.shop
CORS_ORIGINS=https://rankage.shop,https://www.rankage.shop
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
G2BULK_API_KEY=your-g2bulk-api-key

SMTP_HOST=mail.rankage.shop
SMTP_PORT=587
SMTP_USER=noreply@rankage.shop
SMTP_PASS=your-smtp-password
SMTP_FROM=MVPMMSHOP <noreply@rankage.shop>

FIREBASE_SERVICE_ACCOUNT_JSON=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@rankage.shop
