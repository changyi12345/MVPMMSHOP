# Copy to android/keystore.properties and fill in values.
# Generate keystore:
#   keytool -genkeypair -v -storetype PKCS12 -keystore mvpmms-release.keystore -alias mvpmms -keyalg RSA -keysize 2048 -validity 10000
#
# NEVER commit keystore.properties or .keystore files to git.

storeFile=app/mvpmms-release.keystore
storePassword=your-store-password
keyAlias=mvpmms
keyPassword=your-key-password
