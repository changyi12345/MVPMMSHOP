{
  "name": "mvpmms-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "npm run build && playwright test",
    "postinstall": "node -e \"if(process.env.NODE_ENV==='production')process.exit(0)\" || playwright install chromium"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "next": "14",
    "react": "^18",
    "react-dom": "^18"
  },
  "optionalDependencies": {
    "@next/swc-linux-x64-gnu": "14.2.28",
    "@next/swc-linux-x64-musl": "14.2.28"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14",
    "typescript": "^5"
  }
}
