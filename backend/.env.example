# Copy to backend/.env and fill in values

DATABASE_URL=postgresql://user:password@localhost:5432/mvpmms
# Supabase: use Session pooler URL with sslmode=require (see Supabase Dashboard → Connect)
# DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
PORT=4000
JWT_SECRET=change-to-long-random-string-min-32-chars
APP_BASE_URL=https://rankage.shop
CORS_ORIGINS=http://localhost:3000,https://rankage.shop,https://www.rankage.shop

# Google OAuth — Web client ID from Google Cloud Console (OAuth 2.0)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Optional: extra client IDs (Android/iOS) comma-separated for mobile idToken verification
# GOOGLE_CLIENT_IDS=android-client-id.apps.googleusercontent.com

# G2Bulk — required for auto game/voucher fulfillment (or set in Admin → Settings → Integrations)
G2BULK_API_KEY=your-g2bulk-api-key

# Email (optional — or configure in Admin → Settings → Integrations)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MVPMMSHOP <noreply@example.com>

NODE_ENV=development

# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@rankage.shop

# Firebase Cloud Messaging (mobile push) — single-line JSON from Firebase service account
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: Twilio SMS (or configure feature flags in Admin → Settings)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
